# Copy to .env for local development, or set these in Appliku (production).

DJANGO_ENV=development
SECRET_KEY=change-me

# Comma-separated hostnames (no scheme). Production also auto-includes dantrum.com hosts when DJANGO_ENV=production.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins with scheme (required for session-auth POST/PUT in production).
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Comma-separated origins with scheme.
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

DATABASE_URL=postgres://user:password@db:5432/dantrum

# Auth0 (required for login)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Optional
SLACK_WEBHOOK_URL=

# Frontend build (Vite) — tags Sentry events (defaults: production when built for prod, else development)
# VITE_SENTRY_ENVIRONMENT=production

# --- Production (Appliku) ---
# DJANGO_ENV=production
# ALLOWED_HOSTS=dantrum.com,www.dantrum.com,dantrum.applikuapp.com
# CSRF_TRUSTED_ORIGINS=https://dantrum.com,https://www.dantrum.com,https://dantrum.applikuapp.com
# CORS_ALLOWED_ORIGINS=https://dantrum.com,https://www.dantrum.com,https://dantrum.applikuapp.com
